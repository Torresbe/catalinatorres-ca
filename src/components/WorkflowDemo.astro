---
import { getLangFromUrl } from '../i18n/util';
const lang = getLangFromUrl(Astro.url);
const labels = lang === 'es'
  ? {
      folio: 'MS. folio 1 — sugerencia de flujos',
      heading: 'Describe un problema. Recibe un flujo sugerido.',
      marginalia: 'Describe tu problema operativo en 1–3 frases. Inglés o español.',
      placeholder: 'Ejemplo: tengo 500 PDFs académicos en inglés y español que necesito clasificar por tema y de los que hay que extraer hallazgos clave.',
      button: '[ Sugerir flujo → ]',
    }
  : {
      folio: 'MS. folio 1 — workflow suggester',
      heading: 'Describe a problem. Get a suggested workflow.',
      marginalia: 'Describe your operational problem in 1–3 sentences. English or Spanish.',
      placeholder: 'Example: I have 500 academic PDFs in English and Spanish that I need to classify by topic and extract key findings from.',
      button: '[ Suggest workflow → ]',
    };
---
<section class="demo" id="suggest">
  <p class="label">{labels.folio}</p>
  <h3>{labels.heading}</h3>
  <p class="marginalia">{labels.marginalia}</p>
  <form id="suggest-form">
    <textarea name="input" rows="5" placeholder={labels.placeholder} maxlength="2000" required></textarea>
    <button type="submit">{labels.button}</button>
  </form>
  <div class="output" id="suggest-output" hidden></div>
</section>

<script>
  import { errorMessages, type ErrorCode } from '../lib/errors';
  import type { EditorReview, Flow, FlowNode } from '../lib/claude';

  const form = document.getElementById('suggest-form') as HTMLFormElement;
  const output = document.getElementById('suggest-output')!;
  const button = form.querySelector('button')!;
  const lang: 'en' | 'es' = document.documentElement.lang === 'es' ? 'es' : 'en';

  const ui = {
    en: {
      drafting: '[ drafting… ]', progress: 'drafting workflow…', send: '[ Suggest workflow → ]',
      typeLabels: { trigger: 'TRIGGER', action: 'ACTION', result: 'RESULT' },
      reviewLabel: "editor's note",
      confidence: { high: 'high confidence', medium: 'medium confidence', low: 'low confidence' },
      assumes: 'what this assumes', breaks: 'where it can break', check: 'before building it:',
    },
    es: {
      drafting: '[ redactando… ]', progress: 'redactando flujo…', send: '[ Sugerir flujo → ]',
      typeLabels: { trigger: 'INICIO', action: 'ACCIÓN', result: 'RESULTADO' },
      reviewLabel: 'nota del editor',
      confidence: { high: 'confianza alta', medium: 'confianza media', low: 'confianza baja' },
      assumes: 'lo que asume', breaks: 'dónde puede romperse', check: 'antes de construirlo:',
    },
  }[lang];

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = (form.elements.namedItem('input') as HTMLTextAreaElement).value;
    button.disabled = true;
    button.textContent = ui.drafting;
    output.removeAttribute('hidden');
    output.innerHTML = `<p class="marginalia">${ui.progress}</p>`;

    try {
      const res = await fetch('/api/suggest-workflow', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ input }),
      });
      const data = await res.json();
      if (!data.ok) {
        output.innerHTML = renderError(data.code);
      } else {
        output.innerHTML = renderFlow(data.flow);
      }
    } catch {
      output.innerHTML = renderError(504);
    } finally {
      button.disabled = false;
      button.textContent = ui.send;
    }
  });

  function renderError(code: number): string {
    const msg = errorMessages[lang][code as ErrorCode] ?? errorMessages[lang][500];
    return `<div class="err"><span class="code">ERROR ${code}</span> — <span>${msg}</span></div>`;
  }

  function escapeHtml(s: unknown): string {
    return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function renderFlow(flow: Flow): string {
    const stepsHTML = flow.steps
      .map((s, i) => `<li><span class="step-num">${i + 1}</span><span class="step-text">${escapeHtml(s)}</span></li>`)
      .join('');
    return `
      <p class="flow-hook">${escapeHtml(flow.hook)}</p>
      <ol class="flow-steps">${stepsHTML}</ol>
      <div class="flow-diagram">${renderDiagram(flow.nodes)}</div>
      <p class="flow-closer">${escapeHtml(flow.closer)}</p>
      ${flow.review ? renderReview(flow.review) : ''}
    `;
  }

  function renderReview(review: EditorReview): string {
    const list = (items: string[]) =>
      `<ul class="review-list">${items.map((s) => `<li>${escapeHtml(s)}</li>`).join('')}</ul>`;
    return `
      <aside class="flow-review">
        <p class="review-folio">${ui.reviewLabel} — ${ui.confidence[review.confidence]}</p>
        <p class="review-heading">${ui.assumes}</p>
        ${list(review.assumptions)}
        <p class="review-heading">${ui.breaks}</p>
        ${list(review.risks)}
        <p class="review-check"><span class="review-check-label">${ui.check}</span> ${escapeHtml(review.humanCheck)}</p>
      </aside>
    `;
  }

  function renderDiagram(nodes: FlowNode[]): string {
    return nodes
      .map((n, i) => {
        const card = `
          <div class="flow-card flow-card-${n.type}">
            <span class="flow-card-type">${ui.typeLabels[n.type]}</span>
            <span class="flow-card-label">${escapeHtml(n.label)}</span>
          </div>
        `;
        const arrow = i < nodes.length - 1 ? `<span class="flow-arrow" aria-hidden="true">→</span>` : '';
        return card + arrow;
      })
      .join('');
  }
</script>

<style>
  .demo { margin-bottom: var(--s-16); }
  .demo h3 { margin: var(--s-3) 0 var(--s-3); }
  form { margin-top: var(--s-4); }
  textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    background: var(--paper);
    border: 1px dashed var(--divider);
    padding: var(--s-4);
    color: var(--ink);
    resize: vertical;
  }
  button {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    background: transparent;
    border: 1px solid var(--ink);
    padding: var(--s-3) var(--s-4);
    margin-top: var(--s-3);
    color: var(--ink);
    cursor: pointer;
  }
  button:hover:not(:disabled) { background: var(--ink); color: var(--paper); }
  button:disabled { opacity: 0.6; cursor: wait; }
  .output {
    margin-top: var(--s-6);
    padding-top: var(--s-4);
    border-top: 1px dashed var(--divider);
  }
  /* Dynamic elements created via innerHTML lack Astro's data-astro-cid
     attribute, so scoped selectors don't match. Use :global() so the
     CSS reaches them. */
  :global(#suggest-output .err) { font-family: var(--font-body); font-size: var(--text-sm); }
  :global(#suggest-output .err .code) { color: var(--red); font-weight: 700; }

  :global(#suggest-output .flow-hook) {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 var(--s-6);
  }
  :global(#suggest-output .flow-steps) {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--s-8);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
  }
  :global(#suggest-output .flow-steps li) {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--s-3);
    margin-bottom: var(--s-3);
  }
  :global(#suggest-output .step-num) {
    color: var(--red);
    font-weight: 700;
  }
  :global(#suggest-output .step-text) { color: var(--ink); }

  :global(#suggest-output .flow-diagram) {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: flex-start;
    gap: var(--s-3);
    margin: var(--s-6) 0;
  }
  :global(#suggest-output .flow-card) {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--s-1);
    min-width: 130px;
    max-width: 180px;
    flex: 0 1 auto;
    padding: var(--s-3) var(--s-4);
    background: var(--paper);
    border: 1.5px solid var(--divider);
    border-radius: 4px;
  }
  :global(#suggest-output .flow-card-trigger) { border-style: solid; }
  :global(#suggest-output .flow-card-action) { border-style: solid; }
  :global(#suggest-output .flow-card-result) { border-width: 2px; }
  :global(#suggest-output .flow-card-type) {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--red);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  :global(#suggest-output .flow-card-label) {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--ink);
    line-height: 1.3;
    word-break: break-word;
  }
  :global(#suggest-output .flow-arrow) {
    align-self: center;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--divider);
    line-height: 1;
    user-select: none;
  }

  :global(#suggest-output .flow-closer) {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--ink);
    border-top: 1px dashed var(--divider);
    padding-top: var(--s-4);
    margin: var(--s-8) 0 0;
    font-style: italic;
  }

  :global(#suggest-output .flow-review) {
    margin-top: var(--s-8);
    padding: var(--s-4) var(--s-5);
    border: 1.5px solid var(--divider);
    border-radius: 4px;
    background: rgba(160,130,90,0.06);
  }
  :global(#suggest-output .review-folio) {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--red);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 var(--s-3);
  }
  :global(#suggest-output .review-heading) {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--marginalia);
    margin: var(--s-3) 0 var(--s-1);
  }
  :global(#suggest-output .review-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--ink);
  }
  :global(#suggest-output .review-list li) {
    padding-left: var(--s-4);
    position: relative;
    margin-bottom: var(--s-1);
  }
  :global(#suggest-output .review-list li)::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--marginalia);
  }
  :global(#suggest-output .review-check) {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--ink);
    border-top: 1px dashed var(--divider);
    padding-top: var(--s-3);
    margin: var(--s-4) 0 0;
  }
  :global(#suggest-output .review-check-label) {
    color: var(--red);
  }

  @media (max-width: 640px) {
    :global(#suggest-output .flow-card) {
      min-width: 100%;
      max-width: 100%;
      padding: var(--s-2) var(--s-3);
    }
    :global(#suggest-output .flow-card-label) { font-size: var(--text-sm); }
    :global(#suggest-output .flow-arrow) {
      align-self: center;
      transform: rotate(90deg);
    }
  }
</style>
