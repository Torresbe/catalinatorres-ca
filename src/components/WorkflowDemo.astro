---
import { getLangFromUrl } from '../i18n/util';
const lang = getLangFromUrl(Astro.url);
const labels = lang === 'es'
  ? {
      folio: 'MS. folio 2 — sugerencia de flujos',
      heading: 'Describe un problema. Recibe un flujo sugerido.',
      marginalia: 'Describe tu problema operativo en 1–3 frases. Inglés o español.',
      placeholder: 'Ejemplo: tengo 500 PDFs académicos en inglés y español que necesito clasificar por tema y de los que hay que extraer hallazgos clave.',
      button: '[ Sugerir flujo → ]',
      summaryLabel: 'resumen',
      flowLabel: 'flujo',
      estimateLabel: 'esfuerzo estimado',
    }
  : {
      folio: 'MS. folio 2 — workflow suggester',
      heading: 'Describe a problem. Get a suggested workflow.',
      marginalia: 'Describe your operational problem in 1–3 sentences. English or Spanish.',
      placeholder: 'Example: I have 500 academic PDFs in English and Spanish that I need to classify by topic and extract key findings from.',
      button: '[ Suggest workflow → ]',
      summaryLabel: 'summary',
      flowLabel: 'flow',
      estimateLabel: 'estimated effort',
    };
---
<section class="demo" id="suggest">
  <p class="label">{labels.folio}</p>
  <h3>{labels.heading}</h3>
  <p class="marginalia">{labels.marginalia}</p>
  <form id="suggest-form">
    <textarea name="input" rows="5" placeholder={labels.placeholder} maxlength="2000" required></textarea>
    <button type="submit">{labels.button}</button>
  </form>
  <div class="output" id="suggest-output" hidden></div>
</section>

<script>
  import { errorMessages, type ErrorCode } from '../lib/errors';
  import type { Flow, FlowNode, FlowEdge } from '../lib/claude';

  const form = document.getElementById('suggest-form') as HTMLFormElement;
  const output = document.getElementById('suggest-output')!;
  const button = form.querySelector('button')!;
  const lang: 'en' | 'es' = document.documentElement.lang === 'es' ? 'es' : 'en';

  const ui = {
    en: {
      drafting: '[ drafting… ]',
      progress: 'drafting workflow…',
      send: '[ Suggest workflow → ]',
      summary: 'summary',
      flow: 'flow',
      estimate: 'estimated effort',
    },
    es: {
      drafting: '[ redactando… ]',
      progress: 'redactando flujo…',
      send: '[ Sugerir flujo → ]',
      summary: 'resumen',
      flow: 'flujo',
      estimate: 'esfuerzo estimado',
    },
  }[lang];

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = (form.elements.namedItem('input') as HTMLTextAreaElement).value;
    button.disabled = true;
    button.textContent = ui.drafting;
    output.removeAttribute('hidden');
    output.innerHTML = `<p class="marginalia">${ui.progress}</p>`;

    try {
      const res = await fetch('/api/suggest-workflow', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ input }),
      });
      const data = await res.json();
      if (!data.ok) {
        output.innerHTML = renderError(data.code);
      } else {
        output.innerHTML = renderFlow(data.flow);
      }
    } catch {
      output.innerHTML = renderError(504);
    } finally {
      button.disabled = false;
      button.textContent = ui.send;
    }
  });

  function renderError(code: number): string {
    const msg = errorMessages[lang][code as ErrorCode] ?? errorMessages[lang][500];
    return `<div class="err"><span class="code">ERROR ${code}</span> — <span>${msg}</span></div>`;
  }

  function escapeHtml(s: unknown): string {
    return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function renderFlow(flow: Flow): string {
    const svg = renderFlowSVG(flow.nodes, flow.edges);
    return `
      <div class="flow-block">
        <p class="flow-label">§ ${ui.summary}</p>
        <p class="flow-summary">${escapeHtml(flow.summary)}</p>
      </div>
      <div class="flow-block">
        <p class="flow-label">§ ${ui.flow}</p>
        <div class="flow-svg-wrap">${svg}</div>
      </div>
      <div class="flow-block">
        <p class="flow-label">§ ${ui.estimate}</p>
        <p class="flow-estimate">${escapeHtml(flow.estimate)}</p>
      </div>
    `;
  }

  // -------- SVG layout --------

  const NODE_W = 220;
  const NODE_H = 60;
  const LEVEL_GAP = 44;
  const COL_GAP = 28;
  const PAD = 14;

  function computeLevels(nodes: FlowNode[], edges: FlowEdge[]): Map<string, number> {
    const incoming = new Map<string, string[]>();
    const outgoing = new Map<string, string[]>();
    for (const n of nodes) { incoming.set(n.id, []); outgoing.set(n.id, []); }
    for (const e of edges) {
      incoming.get(e.to)?.push(e.from);
      outgoing.get(e.from)?.push(e.to);
    }
    const indeg = new Map<string, number>();
    for (const n of nodes) indeg.set(n.id, incoming.get(n.id)!.length);

    const order: string[] = [];
    const queue = nodes.filter((n) => indeg.get(n.id) === 0).map((n) => n.id);
    while (queue.length) {
      const id = queue.shift()!;
      order.push(id);
      for (const child of outgoing.get(id)!) {
        indeg.set(child, indeg.get(child)! - 1);
        if (indeg.get(child) === 0) queue.push(child);
      }
    }

    const level = new Map<string, number>();
    for (const id of order) {
      const parents = incoming.get(id)!;
      const maxParent = parents.length ? Math.max(...parents.map((p) => level.get(p) ?? 0)) : -1;
      level.set(id, maxParent + 1);
    }
    // Any node not in topo (shouldn't happen on validated DAG) → level 0
    for (const n of nodes) if (!level.has(n.id)) level.set(n.id, 0);
    return level;
  }

  function renderFlowSVG(nodes: FlowNode[], edges: FlowEdge[]): string {
    const level = computeLevels(nodes, edges);
    const byLevel = new Map<number, string[]>();
    for (const [id, lvl] of level) {
      if (!byLevel.has(lvl)) byLevel.set(lvl, []);
      byLevel.get(lvl)!.push(id);
    }
    const levels = [...byLevel.keys()].sort((a, b) => a - b);
    const maxCols = Math.max(...levels.map((l) => byLevel.get(l)!.length));
    const width = maxCols * NODE_W + (maxCols - 1) * COL_GAP + PAD * 2;
    const height = levels.length * NODE_H + (levels.length - 1) * LEVEL_GAP + PAD * 2;

    const pos = new Map<string, { x: number; y: number }>();
    for (const lvl of levels) {
      const ids = byLevel.get(lvl)!;
      const rowW = ids.length * NODE_W + (ids.length - 1) * COL_GAP;
      const startX = (width - rowW) / 2;
      const y = PAD + lvl * (NODE_H + LEVEL_GAP);
      ids.forEach((id, i) => pos.set(id, { x: startX + i * (NODE_W + COL_GAP), y }));
    }

    const edgeSVG = edges.map((e) => {
      const a = pos.get(e.from)!;
      const b = pos.get(e.to)!;
      const x1 = a.x + NODE_W / 2;
      const y1 = a.y + NODE_H;
      const x2 = b.x + NODE_W / 2;
      const y2 = b.y - 4;
      const labelSVG = e.label
        ? `<text x="${(x1 + x2) / 2 + 6}" y="${(y1 + y2) / 2}" class="flow-edge-label">${escapeHtml(e.label)}</text>`
        : '';
      return `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" class="flow-edge" marker-end="url(#flow-arrow)" />${labelSVG}`;
    }).join('');

    const nodeSVG = nodes.map((n) => {
      const p = pos.get(n.id)!;
      const typeLabel = n.type.toUpperCase();
      return `
        <g transform="translate(${p.x}, ${p.y})">
          <rect width="${NODE_W}" height="${NODE_H}" class="flow-node-rect flow-node-${n.type}" />
          <text x="10" y="16" class="flow-node-type">${typeLabel}</text>
          <text x="10" y="40" class="flow-node-label">${escapeHtml(truncate(n.label, 30))}</text>
        </g>
      `;
    }).join('');

    return `
      <svg viewBox="0 0 ${width} ${height}" class="flow-svg" role="img" aria-label="suggested workflow diagram" preserveAspectRatio="xMidYMin meet">
        <defs>
          <marker id="flow-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" class="flow-arrow-head" />
          </marker>
        </defs>
        ${edgeSVG}
        ${nodeSVG}
      </svg>
    `;
  }

  function truncate(s: string, n: number): string {
    return s.length > n ? s.slice(0, n - 1) + '…' : s;
  }
</script>

<style>
  .demo { margin-bottom: var(--s-16); }
  .demo h3 { margin: var(--s-3) 0 var(--s-3); }
  form { margin-top: var(--s-4); }
  textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    background: var(--paper);
    border: 1px dashed var(--divider);
    padding: var(--s-4);
    color: var(--ink);
    resize: vertical;
  }
  button {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    background: transparent;
    border: 1px solid var(--ink);
    padding: var(--s-3) var(--s-4);
    margin-top: var(--s-3);
    color: var(--ink);
    cursor: pointer;
  }
  button:hover:not(:disabled) { background: var(--ink); color: var(--paper); }
  button:disabled { opacity: 0.6; cursor: wait; }
  .output {
    margin-top: var(--s-6);
    padding-top: var(--s-4);
    border-top: 1px dashed var(--divider);
  }
  /* Dynamic elements created via innerHTML lack Astro's data-astro-cid
     attribute, so scoped selectors don't match. Use :global() so the
     CSS reaches them. */
  :global(#suggest-output .err) { font-family: var(--font-body); font-size: var(--text-sm); }
  :global(#suggest-output .err .code) { color: var(--red); font-weight: 700; }

  :global(#suggest-output .flow-block) { margin-bottom: var(--s-5); }
  :global(#suggest-output .flow-label) {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-muted, var(--ink));
    opacity: 0.7;
    margin: 0 0 var(--s-2);
  }
  :global(#suggest-output .flow-summary),
  :global(#suggest-output .flow-estimate) {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin: 0;
  }
  :global(#suggest-output .flow-svg-wrap) {
    width: 100%;
    overflow-x: auto;
  }
  :global(#suggest-output .flow-svg) {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
    font-family: var(--font-body);
  }
  :global(#suggest-output .flow-node-rect) {
    fill: var(--paper);
    stroke: var(--ink);
    stroke-width: 1;
  }
  :global(#suggest-output .flow-node-trigger) { stroke-dasharray: 0; }
  :global(#suggest-output .flow-node-condition) { stroke-dasharray: 4 3; }
  :global(#suggest-output .flow-node-output) { stroke-width: 2; }
  :global(#suggest-output .flow-node-type) {
    font-size: 10px;
    letter-spacing: 0.08em;
    fill: var(--ink);
    opacity: 0.55;
  }
  :global(#suggest-output .flow-node-label) {
    font-size: 13px;
    fill: var(--ink);
  }
  :global(#suggest-output .flow-edge) {
    stroke: var(--ink);
    stroke-width: 1;
    fill: none;
  }
  :global(#suggest-output .flow-edge-label) {
    font-size: 10px;
    fill: var(--ink);
    opacity: 0.7;
  }
  :global(#suggest-output .flow-arrow-head) {
    fill: var(--ink);
  }
</style>
