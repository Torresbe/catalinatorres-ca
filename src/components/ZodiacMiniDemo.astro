---
import { getLangFromUrl } from '../i18n/util';
const lang = getLangFromUrl(Astro.url);

const signsData = [
  { slug: 'aries',
    label: { en: 'Aries (Mar 21 – Apr 19)', es: 'Aries (21 mar – 19 abr)' },
    title: 'Rayuela', author: 'Julio Cortázar',
    why: { en: 'You pick your own order. Aries needs a book that lets them run the engine.',
           es: 'Tú escoges el orden. Aries necesita un libro que lo deje conducir el motor.' }},
  { slug: 'taurus',
    label: { en: 'Taurus (Apr 20 – May 20)', es: 'Tauro (20 abr – 20 may)' },
    title: 'The Lover', author: 'Marguerite Duras',
    why: { en: 'Slow, sensory, confident in pleasure. Taurus reads the world through texture.',
           es: 'Lento, sensorial, seguro en el placer. Tauro lee el mundo a través de la textura.' }},
  { slug: 'gemini',
    label: { en: 'Gemini (May 21 – Jun 20)', es: 'Géminis (21 may – 20 jun)' },
    title: "If on a winter's night a traveler", author: 'Italo Calvino',
    why: { en: 'Ten novels inside one. Gemini keeps two minds at once.',
           es: 'Diez novelas dentro de una. Géminis sostiene dos mentes a la vez.' }},
  { slug: 'cancer',
    label: { en: 'Cancer (Jun 21 – Jul 22)', es: 'Cáncer (21 jun – 22 jul)' },
    title: 'Beloved', author: 'Toni Morrison',
    why: { en: 'Family, memory, haunting as love. Cancer carries the house on their back.',
           es: 'Familia, memoria, hechizo como amor. Cáncer carga la casa a la espalda.' }},
  { slug: 'leo',
    label: { en: 'Leo (Jul 23 – Aug 22)', es: 'Leo (23 jul – 22 ago)' },
    title: 'Wide Sargasso Sea', author: 'Jean Rhys',
    why: { en: "Identity claimed back from someone else's story. Leo refuses to be a footnote.",
           es: 'Identidad reclamada de la historia de otro. Leo se niega a ser una nota al pie.' }},
  { slug: 'virgo',
    label: { en: 'Virgo (Aug 23 – Sep 22)', es: 'Virgo (23 ago – 22 sep)' },
    title: 'The Remains of the Day', author: 'Kazuo Ishiguro',
    why: { en: 'Precision of detail, pain of omission. Virgo will notice every missed gesture.',
           es: 'Precisión del detalle, dolor de la omisión. Virgo nota cada gesto que falta.' }},
  { slug: 'libra',
    label: { en: 'Libra (Sep 23 – Oct 22)', es: 'Libra (23 sep – 22 oct)' },
    title: 'Pride and Prejudice', author: 'Jane Austen',
    why: { en: "Balance, manners, moral judgement negotiated in a drawing room. Libra's home turf.",
           es: 'Equilibrio, modales, juicio moral negociado en una sala de estar. Cancha de Libra.' }},
  { slug: 'scorpio',
    label: { en: 'Scorpio (Oct 23 – Nov 21)', es: 'Escorpio (23 oct – 21 nov)' },
    title: 'Blood Meridian', author: 'Cormac McCarthy',
    why: { en: "Absolute in its darkness. Scorpio doesn't look away; they read closer.",
           es: 'Absoluto en su oscuridad. Escorpio no aparta la vista; lee más cerca.' }},
  { slug: 'sagittarius',
    label: { en: 'Sagittarius (Nov 22 – Dec 21)', es: 'Sagitario (22 nov – 21 dic)' },
    title: 'The Master and Margarita', author: 'Mikhail Bulgakov',
    why: { en: 'Big, wild, funny, blasphemous, humanist. Sagittarius expands or dies.',
           es: 'Grande, salvaje, divertido, blasfemo, humanista. Sagitario se expande o muere.' }},
  { slug: 'capricorn',
    label: { en: 'Capricorn (Dec 22 – Jan 19)', es: 'Capricornio (22 dic – 19 ene)' },
    title: 'The Emperor of All Maladies', author: 'Siddhartha Mukherjee',
    why: { en: 'Patient, disciplined, serious. Capricorn wants mastery and the long view.',
           es: 'Paciente, disciplinado, serio. Capricornio quiere maestría y mirada larga.' }},
  { slug: 'aquarius',
    label: { en: 'Aquarius (Jan 20 – Feb 18)', es: 'Acuario (20 ene – 18 feb)' },
    title: 'Never Let Me Go', author: 'Kazuo Ishiguro',
    why: { en: 'Unusual ethics, unusual kindness, the problem of designing people. Aquarius territory.',
           es: 'Ética inusual, bondad inusual, el problema de diseñar gente. Territorio de Acuario.' }},
  { slug: 'pisces',
    label: { en: 'Pisces (Feb 19 – Mar 20)', es: 'Piscis (19 feb – 20 mar)' },
    title: 'The Solitudes', author: 'Luis de Góngora',
    why: { en: 'Oceanic, hallucinatory, undone by beauty. Pisces drifts on purpose.',
           es: 'Oceánico, alucinatorio, deshecho por la belleza. Piscis a la deriva a propósito.' }},
];

const signs = signsData.map((s) => ({
  slug: s.slug,
  label: s.label[lang],
  rec: { title: s.title, author: s.author, why: s.why[lang] },
}));

const labels = lang === 'es'
  ? { tryIt: '[ PRUÉBALO ] — demo reducido', heading: 'Elige un signo. Recibe un libro.', signLabel: 'Signo', choose: 'elige —', rec: 'RECOMENDACIÓN' }
  : { tryIt: '[ TRY IT ] — reduced demo', heading: 'Pick a sign. Get a book.', signLabel: 'Sign', choose: 'choose —', rec: 'RECOMMENDATION' };
---
<section class="demo" data-signs={JSON.stringify(signs)}>
  <p class="label">{labels.tryIt}</p>
  <h3>{labels.heading}</h3>
  <div class="pick">
    <label for="sign">{labels.signLabel}</label>
    <select id="sign">
      <option value="">{labels.choose}</option>
      {signs.map((s) => <option value={s.slug}>{s.label}</option>)}
    </select>
  </div>
  <div class="out" id="sign-out" hidden>
    <p class="label" id="out-label">{labels.rec}</p>
    <h4 id="out-title"></h4>
    <p class="attr" id="out-author"></p>
    <p class="why" id="out-why"></p>
  </div>
</section>

<script>
  const section = document.querySelector('.demo') as HTMLElement;
  const signs = JSON.parse(section.dataset.signs!);
  const sel = document.getElementById('sign') as HTMLSelectElement;
  const out = document.getElementById('sign-out')!;
  sel.addEventListener('change', () => {
    const s = signs.find((x: any) => x.slug === sel.value);
    if (!s) { out.setAttribute('hidden', ''); return; }
    (document.getElementById('out-title')!).textContent = s.rec.title;
    (document.getElementById('out-author')!).textContent = '— ' + s.rec.author;
    (document.getElementById('out-why')!).textContent = s.rec.why;
    out.removeAttribute('hidden');
  });
</script>

<style>
  .demo { margin-top: var(--s-12); padding: var(--s-8); border: 1px dashed var(--divider); background: rgba(160,130,90,0.03); }
  .demo h3 { margin: var(--s-3) 0 var(--s-6); }
  .pick { display: flex; gap: var(--s-4); align-items: center; margin-bottom: var(--s-6); }
  .pick label { font-family: var(--font-body); font-size: var(--text-sm); color: var(--marginalia); }
  .pick select {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    padding: var(--s-2) var(--s-3);
    background: var(--paper);
    border: 1px solid var(--divider);
    color: var(--ink);
  }
  .out { border-top: 1px dashed var(--divider); padding-top: var(--s-4); }
  .out h4 { font-family: var(--font-display); font-size: var(--text-xl); margin: var(--s-2) 0; }
  .attr { color: var(--marginalia); margin: 0 0 var(--s-3); font-size: var(--text-sm); }
  .why { line-height: 1.6; }
</style>
