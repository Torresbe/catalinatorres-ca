---
import { getLangFromUrl } from '../i18n/util';
const lang = getLangFromUrl(Astro.url);

type Node = { id: string; text: string; choices?: { label: string; next: string }[]; ending?: boolean };

const nodesEN: Node[] = [
  {
    id: 'start',
    text: 'INSTRUCTIONS FOR WINDING THE CLOCK. The clock is small, on the table by the window, and it has stopped. You will turn the key three full turns to the right, gently. You will feel the spring tighten with each rotation. After the third turn, the mechanism is wound. Now read on — there is one decision to make.',
    choices: [{ label: 'continue reading', next: 'fork' }],
  },
  {
    id: 'fork',
    text: 'Place the hour hand at the right time. The instructions allow two readings of "the right time" and the clock honours both. Choose one.',
    choices: [
      { label: 'set it to the time on your wrist', next: 'wrist' },
      { label: 'set it to the time the previous owner kept', next: 'previous' },
    ],
  },
  {
    id: 'wrist',
    text: 'The clock starts with a small click and ticks in time with the rest of the room. By morning you have stopped noticing it. This ending was written for a reader who synchronized.',
    ending: true,
  },
  {
    id: 'previous',
    text: 'The clock starts and runs four minutes ahead of every other clock in the house. You leave it that way. By the third night you find yourself trusting it more than the others. This ending was written for a reader who let the past decide.',
    ending: true,
  },
];

const nodesES: Node[] = [
  {
    id: 'start',
    text: 'INSTRUCCIONES PARA DARLE CUERDA AL RELOJ. El reloj es pequeño, sobre la mesa junto a la ventana, y se ha detenido. Darás tres vueltas completas a la llave hacia la derecha, con suavidad. Sentirás el resorte tensarse con cada rotación. Después de la tercera vuelta, el mecanismo está cargado. Sigue leyendo — hay una sola decisión que tomar.',
    choices: [{ label: 'seguir leyendo', next: 'fork' }],
  },
  {
    id: 'fork',
    text: 'Coloca la aguja horaria en la hora correcta. Las instrucciones admiten dos lecturas de "la hora correcta" y el reloj honra las dos. Elige una.',
    choices: [
      { label: 'ponla en la hora que marca tu muñeca', next: 'wrist' },
      { label: 'ponla en la hora que tenía el dueño anterior', next: 'previous' },
    ],
  },
  {
    id: 'wrist',
    text: 'El reloj arranca con un pequeño clic y comienza a marcar el tiempo al unísono con el resto del cuarto. Por la mañana ya has dejado de notarlo. Este final fue escrito para un lector que sincronizó.',
    ending: true,
  },
  {
    id: 'previous',
    text: 'El reloj arranca y avanza cuatro minutos por delante de los demás relojes de la casa. Lo dejas así. Para la tercera noche te encuentras confiando en él más que en los otros. Este final fue escrito para un lector que dejó que decidiera el pasado.',
    ending: true,
  },
];

const nodes = lang === 'es' ? nodesES : nodesEN;

const labels = lang === 'es'
  ? { tryIt: '[ PRUÉBALO ] — demo de narrativa con bifurcaciones', heading: 'Instrucciones, en dos lecturas.', restart: 'reiniciar' }
  : { tryIt: '[ TRY IT ] — branching narrative demo', heading: 'Instructions, in two readings.', restart: 'restart' };
---
<section class="demo" data-nodes={JSON.stringify(nodes)}>
  <p class="label">{labels.tryIt}</p>
  <h3>{labels.heading}</h3>
  <div class="stage">
    <p class="text" id="story-text"></p>
    <div class="choices" id="story-choices"></div>
    <button class="restart" id="story-restart" hidden>{labels.restart}</button>
  </div>
</section>

<script>
  const container = document.querySelector('.demo') as HTMLElement;
  const nodes = JSON.parse(container.dataset.nodes!);
  const textEl = document.getElementById('story-text')!;
  const choicesEl = document.getElementById('story-choices')!;
  const restartEl = document.getElementById('story-restart') as HTMLButtonElement;

  function render(id: string) {
    const n = nodes.find((x: any) => x.id === id);
    if (!n) return;
    textEl.textContent = n.text;
    choicesEl.innerHTML = '';
    if (n.ending) {
      restartEl.removeAttribute('hidden');
    } else {
      restartEl.setAttribute('hidden', '');
      n.choices.forEach((c: any) => {
        const btn = document.createElement('button');
        btn.textContent = c.label;
        btn.className = 'choice';
        btn.addEventListener('click', () => render(c.next));
        choicesEl.appendChild(btn);
      });
    }
  }

  restartEl.addEventListener('click', () => render('start'));
  render('start');
</script>

<style>
  .demo { margin-top: var(--s-12); padding: var(--s-8); border: 1px dashed var(--divider); background: rgba(160,130,90,0.03); }
  .demo h3 { margin: var(--s-3) 0 var(--s-6); }
  .stage { min-height: 180px; }
  .text { font-size: var(--text-lg); line-height: 1.55; margin-bottom: var(--s-6); max-width: 640px; }
  .choices { display: flex; flex-direction: column; gap: var(--s-3); align-items: flex-start; }
  .choice, .restart {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    background: transparent;
    border: 1px dashed var(--divider);
    padding: var(--s-3) var(--s-4);
    color: var(--ink);
    cursor: pointer;
  }
  .choice:hover, .restart:hover { border-style: solid; border-color: var(--red); color: var(--red); }
</style>
