---
import { getLangFromUrl, t } from '../i18n/util';
import LangToggle from './LangToggle.astro';

const lang = getLangFromUrl(Astro.url);
const strings = t(lang);
const base = lang === 'es' ? '/es' : '';
const menuLabel = lang === 'es' ? 'Menú' : 'Menu';
const homeHref = base || '/';

const navItems = [
  { href: `${base}/`, label: strings.nav.home },
  { href: `${base}${lang === 'es' ? '/servicios' : '/services'}`, label: strings.nav.services },
  { href: `${base}${lang === 'es' ? '/proyectos' : '/projects'}`, label: strings.nav.projects },
  { href: `${base}/lab`, label: strings.nav.lab },
  { href: `${base}${lang === 'es' ? '/sobre-mi' : '/about'}`, label: strings.nav.about },
  { href: `${base}${lang === 'es' ? '/contacto' : '/contact'}`, label: strings.nav.contact },
];
---
<header id="site-header">
  <div class="wrap">
    <button
      type="button"
      class="hamburger"
      id="nav-toggle"
      aria-controls="main-nav"
      aria-expanded="false"
      aria-label={menuLabel}
    >
      <span aria-hidden="true">☰</span>
    </button>
    <a href={homeHref} class="brand brand-bar" aria-label="catalina torres — home">
      <img src="/favicon.svg" alt="" class="brand-mark" width="72" height="36" />
      <span class="brand-text">catalina torres</span>
    </a>
    <nav id="main-nav">
      {navItems.map(({ href, label }) => (
        <a href={href} class="navlink">{label}</a>
      ))}
      <a href={homeHref} class="brand brand-menu" aria-label="catalina torres — home">
        <img src="/favicon.svg" alt="" class="brand-mark" width="72" height="36" />
        <span class="brand-text">catalina torres</span>
      </a>
      <div class="nav-lang"><LangToggle /></div>
    </nav>
    <div class="lang-slot"><LangToggle /></div>
  </div>
</header>
<script>
  const btn = document.getElementById('nav-toggle');
  const nav = document.getElementById('main-nav');
  const header = document.getElementById('site-header');
  if (btn && nav && header) {
    btn.addEventListener('click', () => {
      const open = header.classList.toggle('nav-open');
      btn.setAttribute('aria-expanded', String(open));
    });
    nav.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName === 'A' || (e.target as HTMLElement).closest('a')) {
        header.classList.remove('nav-open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
<style>
  header {
    border-bottom: 1px dashed var(--divider);
    padding: var(--s-4) 0;
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--paper);
  }
  .wrap {
    max-width: var(--hero-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--s-6);
  }
  .brand-bar { justify-self: start; }
  nav { justify-self: center; }
  .lang-slot { justify-self: end; }
  .hamburger {
    display: none;
    background: transparent;
    border: 1px solid var(--divider);
    border-radius: 3px;
    padding: 4px 10px;
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1;
    color: var(--ink);
    cursor: pointer;
  }
  .hamburger:hover { border-color: var(--ink); }
  .brand {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--ink);
    line-height: 1;
  }
  .brand-mark { display: block; margin-bottom: -2px; }
  .brand-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-lg);
  }
  .brand-menu { display: none; }
  nav { display: flex; align-items: center; gap: var(--s-6); flex-wrap: wrap; }
  .navlink {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
  }
  .navlink:hover { color: var(--red); }
  .nav-lang { display: none; }
  .lang-slot { display: block; }

  @media (max-width: 768px) {
    .wrap {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: var(--s-3);
      align-items: center;
    }
    .hamburger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 40px;
      min-height: 40px;
      justify-self: start;
    }
    .brand-bar { display: inline-flex; justify-self: center; }
    .lang-slot { display: block; justify-self: end; }
    nav {
      display: none;
      grid-column: 1 / -1;
      flex-direction: column;
      align-items: center;
      gap: var(--s-2);
      padding-top: var(--s-4);
      width: auto;
      justify-self: stretch;
      margin: 0 calc(-1 * var(--gutter));
      max-height: calc(100vh - 80px);
      overflow-y: auto;
    }
    .navlink {
      width: 100%;
      text-align: center;
      padding: var(--s-3) 0;
      border-bottom: 1px dashed var(--divider);
      font-size: var(--text-base);
      letter-spacing: 1.5px;
    }
    .brand-menu {
      display: inline-flex;
      align-items: center;
      margin: var(--s-3) 0;
      width: auto;
    }
    .nav-lang {
      display: block;
      padding-top: var(--s-2);
    }
    header.nav-open nav { display: flex; }
  }
</style>
