---
import { getCollection } from 'astro:content';
import Layout from '../../../components/Layout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { projectSlugFromId } from '../../../i18n/util';

const projects = (await getCollection('projects', (e) => e.data.lang === 'es')).sort((a, b) => a.data.order - b.data.order);
const visible = projects.slice(0, 4);
const hidden = projects.slice(4);
---
<Layout title="Proyectos" description="Proyectos entre práctica editorial, académica y automatización con IA.">
  <SectionHeader
    label="[§3] CASOS"
    title="Proyectos"
    subtitle="De la experimentación editorial al diseño de operaciones y flujos nativos de IA, ordenados por años."
  />
  <ul class="list">
    {visible.map((p) => (
      <li>
        <a href={`/es/proyectos/${projectSlugFromId(p.id)}`}>
          <p class="era marginalia">{p.data.era}</p>
          <h3>{p.data.title}</h3>
          <p class="summary">{p.data.summary}</p>
        </a>
      </li>
    ))}
  </ul>
  {hidden.length > 0 && (
    <details class="more">
      <summary>Ver más</summary>
      <ul class="list">
        {hidden.map((p) => (
          <li>
            <a href={`/es/proyectos/${projectSlugFromId(p.id)}`}>
              <p class="era marginalia">{p.data.era}</p>
              <h3>{p.data.title}</h3>
              <p class="summary">{p.data.summary}</p>
            </a>
          </li>
        ))}
      </ul>
    </details>
  )}
</Layout>
<style>
  .list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--s-8); }
  .list li { border-bottom: 1px dashed var(--divider); padding-bottom: var(--s-6); }
  .list li a { text-decoration: none; display: block; }
  .list h3 { margin: var(--s-2) 0 var(--s-3); }
  .list li a:hover h3 { color: var(--red); }
  .summary { font-size: var(--text-sm); color: var(--marginalia); margin: 0 0 var(--s-3); max-width: 600px; }
  .era { margin: 0; }
  .more { margin-top: var(--s-8); }
  .more > summary {
    cursor: pointer;
    list-style: none;
    font-size: var(--text-sm);
    color: var(--marginalia);
    padding-bottom: var(--s-8);
  }
  .more > summary::-webkit-details-marker { display: none; }
  .more > summary::after { content: ' \25BE'; }
  .more[open] > summary::after { content: ' \25B4'; }
  .more > summary:hover { color: var(--red); }
</style>
