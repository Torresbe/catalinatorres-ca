---
import Layout from '../../components/Layout.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const capabilities = [
  { verb: 'editar',     note: 'lo desordenado' },
  { verb: 'automatizar', note: 'lo aburrido' },
  { verb: 'digitalizar', note: 'el pasado' },
  { verb: 'ordenar',    note: 'lo que importa' },
  { verb: 'traducir',   note: 'tech ↔ humano' },
  { verb: 'rescatar',   note: 'de la nada' },
];

const capacities = [
  { name: 'Agentes de correo',         desc: 'que leen, ordenan y responden las preguntas de siempre con respuestas gentiles y automáticas.' },
  { name: 'Calendarios de citas',       desc: 'que dicen "este jueves a las 2" sin tres rondas de mensajes.' },
  { name: 'Organización documental',    desc: 'para el .zip en el escritorio y el cajón que llevas un año sin abrir.' },
  { name: 'Digitalización de extremo a extremo', desc: 'del papel escaneado a una base de datos consultable.' },
  { name: 'Asistentes de IA a la medida', desc: 'que conocen el entorno específico en el que estás y responden en tu lenguaje — no con verdades sueltas, sin contexto.' },
  { name: 'Flujos de IA personalizados', desc: 'para los casos en los que las herramientas estándar se quedan cortas.' },
];
---
<Layout
  title="Soluciones de IA, hechas por una editora"
  description="Catalina Torres — soluciones de IA y consultoría en operaciones desde Edmonton, Canadá."
>
  <section class="hero">
    <h1>Soluciones de IA,<br/><em>hechas por una editora.</em></h1>
    <p class="lede">
      Ver los flujos de trabajo como una editora lee un manuscrito:
      dejar lo que funciona, cambiar lo que se repite, reescribir lo que no es claro.
      Sea software, automatización o una manera más silenciosa de hacer lo mismo,
      el objetivo es siempre acortar lo aburrido y dejar visible lo que importa.
    </p>
  </section>

  <section class="capabilities">
    <ul class="chips">
      {capabilities.map((c) => (
        <li><span class="verb">{c.verb}</span> — {c.note}</li>
      ))}
    </ul>
  </section>

  <hr />

  <section class="capacities">
    <SectionHeader label="OFICINA" title="Lo que hago" />
    <dl>
      {capacities.map((c) => (
        <div>
          <dt>{c.name}</dt>
          <dd>{c.desc}</dd>
        </div>
      ))}
    </dl>
  </section>

  <hr />

  <section class="cta">
    <h2>Dos demos viven en <a href="/es/lab">/es/lab →</a></h2>
    <p class="cta-note">clasificador · sugeridor de flujos · ambos bilingües</p>
  </section>
</Layout>

<style>
  .hero { padding: var(--s-12) 0 var(--s-8); }
  .hero h1 {
    font-size: var(--text-5xl);
    line-height: 1.05;
    margin-bottom: var(--s-6);
  }
  .hero h1 em { font-style: italic; font-weight: 400; }
  .hero .lede {
    max-width: 640px;
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--ink);
    margin: 0;
  }

  .capabilities { margin: var(--s-8) 0 var(--s-12); }
  .capabilities .chips {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px;
  }
  .capabilities .chips li {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    padding: 3px 8px;
    background: rgba(160,130,90,0.06);
    border: 1px solid var(--divider);
    border-radius: 3px;
    color: var(--marginalia);
    letter-spacing: 0.3px;
  }
  .capabilities .chips .verb { color: var(--ink); }

  .capacities dl { margin: 0; }
  .capacities dl > div { margin-bottom: var(--s-6); }
  .capacities dt {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-bottom: var(--s-1);
  }
  .capacities dd {
    margin: 0;
    color: var(--marginalia);
    font-size: var(--text-base);
    line-height: 1.55;
  }

  .cta { padding: var(--s-8) 0 var(--s-16); }
  .cta h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    margin: 0 0 var(--s-2);
  }
  .cta a { color: var(--red); text-decoration: none; }
  .cta-note { color: var(--marginalia); font-size: var(--text-sm); margin: 0; }

  @media (max-width: 480px) {
    .hero h1 { font-size: var(--text-4xl); }
  }
</style>
