---
import Layout from '../components/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';

const capabilities = [
  { verb: 'edit',      note: "what's dirty" },
  { verb: 'automate',  note: "what's boring" },
  { verb: 'digitize',  note: 'the past' },
  { verb: 'sort',      note: 'what matters' },
  { verb: 'translate', note: 'tech ↔ human' },
  { verb: 'rescue',    note: 'from nothingness' },
];

const capacities = [
  { name: 'Email agents',          desc: 'that read, sort, and reply to the usual questions with kind, automatic answers.' },
  { name: 'Booking calendars',     desc: 'that say "this Thursday at 2" without three back-and-forths.' },
  { name: 'Document organization', desc: "for the .zip on your desktop and the cabinet you haven't opened." },
  { name: 'End-to-end digitization', desc: 'from scanned paper to a searchable database.' },
  { name: 'Custom AI assistants',  desc: "that know the specific environment you're in and answer in your language — not with stray truths that have no context." },
  { name: 'Tailored AI workflows', desc: "for the corner cases the off-the-shelf tools weren't built for." },
];
---
<Layout
  title="AI Solutions, built by an editor"
  description="Catalina Torres — AI solutions and operations consulting from Edmonton, Canada."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Catalina Torres Benjumea',
    jobTitle: 'AI Automation Consultant',
    email: 'mailto:catalinatorres1000@gmail.com',
    url: Astro.site!.toString(),
    address: { '@type': 'PostalAddress', addressLocality: 'Edmonton', addressRegion: 'AB', addressCountry: 'CA' },
  })} />
  <section class="hero">
    <h1>AI Solutions,<br/><em>built by an editor.</em></h1>
    <p class="lede">
      The work here is to see workflows the way an editor reads a manuscript:
      keep what works, change what repeats, rewrite what isn't clear. Whether the answer
      is software, automation, or a quieter way of doing the same thing, the goal is
      the same — make the boring parts shorter, the important parts visible.
    </p>
  </section>

  <section class="capabilities">
    <ul class="chips">
      {capabilities.map((c) => (
        <li><span class="verb">{c.verb}</span> — {c.note}</li>
      ))}
    </ul>
  </section>

  <hr />

  <section class="capacities">
    <SectionHeader label="OFFICE" title="What I do" />
    <dl>
      {capacities.map((c) => (
        <div>
          <dt>{c.name}</dt>
          <dd>{c.desc}</dd>
        </div>
      ))}
    </dl>
  </section>

  <hr />

  <section class="cta">
    <h2>Two demos live at <a href="/lab">/lab →</a></h2>
    <p class="cta-note">classifier · workflow suggester · both bilingual</p>
  </section>
</Layout>

<style>
  .hero { padding: var(--s-12) 0 var(--s-8); }
  .hero h1 {
    font-size: var(--text-5xl);
    line-height: 1.05;
    margin-bottom: var(--s-6);
  }
  .hero h1 em { font-style: italic; font-weight: 400; }
  .hero .lede {
    max-width: 640px;
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--ink);
    margin: 0;
  }

  .capabilities { margin: var(--s-8) 0 var(--s-12); }
  .capabilities .chips {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px;
  }
  .capabilities .chips li {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    padding: 3px 8px;
    background: rgba(160,130,90,0.06);
    border: 1px solid var(--divider);
    border-radius: 3px;
    color: var(--marginalia);
    letter-spacing: 0.3px;
  }
  .capabilities .chips .verb { color: var(--ink); }

  .capacities dl { margin: 0; }
  .capacities dl > div { margin-bottom: var(--s-6); }
  .capacities dt {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-bottom: var(--s-1);
  }
  .capacities dd {
    margin: 0;
    color: var(--marginalia);
    font-size: var(--text-base);
    line-height: 1.55;
  }

  .cta { padding: var(--s-8) 0 var(--s-16); }
  .cta h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    margin: 0 0 var(--s-2);
  }
  .cta a { color: var(--red); text-decoration: none; }
  .cta-note { color: var(--marginalia); font-size: var(--text-sm); margin: 0; }

  @media (max-width: 480px) {
    .hero h1 { font-size: var(--text-4xl); }
  }
</style>
